---
import { NAV, ROUTES, UI, localizedPath, type Lang, type PageId } from "../i18n/ui";
import LangSwitcher from "./LangSwitcher.astro";

interface Props {
  lang: Lang;
  current: PageId;
}
const { lang, current } = Astro.props;
const homeHref = localizedPath("home", lang);
---

<header class="nav">
  <div class="nav__inner container">
    <a class="nav__brand" href={homeHref}>
      <span class="nav__brand-name">{UI.brand[lang]}</span>
      <span class="nav__brand-cap">{UI.cap[lang]}</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav__checkbox" />
    <label for="nav-toggle" class="nav__burger" aria-label={UI.menu[lang]}>
      <span></span><span></span><span></span>
    </label>

    <nav class="nav__menu" aria-label="Principal">
      <ul class="nav__list">
        {
          NAV.map((item) => (
            <li>
              <a
                href={ROUTES[item.page][lang]}
                class="nav__link"
                aria-current={current === item.page ? "page" : undefined}
              >
                {item.label[lang]}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="nav__lang">
        <LangSwitcher lang={lang} page={current} />
      </div>
    </nav>
  </div>
</header>

<style lang="scss">
  @use "../styles/tokens" as *;

  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    min-height: 4.5rem;
  }
  .nav__brand {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    text-decoration: none;
    font-family: var(--font-display);
  }
  .nav__brand-name {
    font-weight: 700;
    font-size: var(--step-0);
    letter-spacing: -0.01em;
  }
  .nav__brand-cap {
    font-family: var(--font-body);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-deep);
  }

  .nav__checkbox,
  .nav__burger {
    display: none;
  }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: var(--space-m);
  }
  .nav__list {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2.25rem);
  }
  .nav__link {
    text-decoration: none;
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--ink-2);
    padding-block: 0.5rem;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;

    &:hover {
      color: var(--ink);
    }
    &[aria-current="page"] {
      color: var(--ink);
      border-bottom-color: var(--accent);
    }
  }
  .nav__lang {
    padding-left: var(--space-m);
    border-left: 1px solid var(--line);
  }

  // ── Móvil ──
  @media (max-width: $bp-md) {
    .nav__burger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 2.5rem;
      height: 2.5rem;
      cursor: pointer;

      span {
        display: block;
        height: 2px;
        width: 1.5rem;
        background: var(--ink);
        transition: transform 0.25s ease, opacity 0.2s ease;
      }
    }
    .nav__menu {
      position: fixed;
      inset: 4.5rem 0 auto 0;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-m);
      padding: var(--space-m) var(--space-m) var(--space-l);
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      transform: translateY(-130%);
      transition: transform 0.3s ease;
    }
    .nav__list {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-s);
      width: 100%;
    }
    .nav__link {
      font-size: var(--step-1);
    }
    .nav__lang {
      padding-left: 0;
      border-left: none;
    }
    .nav__checkbox:checked ~ .nav__menu {
      transform: translateY(0);
    }
    .nav__checkbox:checked ~ .nav__burger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav__checkbox:checked ~ .nav__burger span:nth-child(2) {
      opacity: 0;
    }
    .nav__checkbox:checked ~ .nav__burger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
