---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Counter from "../Counter.astro";
import ServiceCard from "../ServiceCard.astro";
import ProjectGrid from "../ProjectGrid.astro";
import CertBadges from "../CertBadges.astro";
import Icon from "../Icon.astro";
import {
  servicios,
  proyectosDestacados,
  stats,
} from "../../lib/content";
import { ROUTES, UI, type Lang } from "../../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const meta = {
  title: {
    es: "Arq. Nelly Cúneo · Consultoría y Auditoría EDGE en Perú",
    en: "Arch. Nelly Cúneo · EDGE Consulting & Auditing in Peru",
  },
  description: {
    es: "Arquitecta bioclimática, EDGE Expert y EDGE Auditor. Consultoría y auditoría de la certificación EDGE para proyectos sostenibles en el Perú y Latinoamérica.",
    en: "Bioclimatic architect, EDGE Expert and EDGE Auditor. EDGE certification consulting and auditing for sustainable projects across Peru and Latin America.",
  },
};

const hero = {
  eyebrow: { es: "Arquitecta · EDGE Expert & Auditor", en: "Architect · EDGE Expert & Auditor" },
  title: {
    es: "Arquitectura sostenible que se certifica",
    en: "Sustainable architecture, certified",
  },
  lead: {
    es: "Consultoría y auditoría de la certificación EDGE para proyectos inmobiliarios, comerciales y del Estado en el Perú y Latinoamérica.",
    en: "EDGE certification consulting and auditing for residential, commercial and government projects across Peru and Latin America.",
  },
};

const stat = {
  proyectos: { es: "Proyectos EDGE", en: "EDGE projects" },
  asesorias: { es: "Asesorías EDGE", en: "EDGE consulting" },
  auditorias: { es: "Auditorías EDGE", en: "EDGE audits" },
  clientes: { es: "Clientes satisfechos", en: "Satisfied clients" },
};

const sections = {
  servicesEyebrow: { es: "Servicios", en: "Services" },
  servicesTitle: { es: "Cómo puedo ayudarte", en: "How I can help" },
  projectsEyebrow: { es: "Portafolio", en: "Portfolio" },
  projectsTitle: { es: "Proyectos destacados", en: "Featured projects" },
  ctaTitle: {
    es: "¿Tienes un proyecto en mente?",
    en: "Have a project in mind?",
  },
  ctaText: {
    es: "Conversemos sobre cómo llevar tu proyecto a la certificación EDGE.",
    en: "Let’s talk about taking your project to EDGE certification.",
  },
};
---

<BaseLayout
  lang={lang}
  page="home"
  title={meta.title[lang]}
  description={meta.description[lang]}
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__text">
        <span class="eyebrow">{hero.eyebrow[lang]}</span>
        <h1 class="hero__title">{hero.title[lang]}</h1>
        <p class="lead hero__lead">{hero.lead[lang]}</p>
        <div class="hero__actions">
          <a class="btn btn--solid" href={ROUTES.contacto[lang]}>
            {UI.ctaContact[lang]}<Icon name="arrow" size={18} />
          </a>
          <a class="btn btn--ghost" href={ROUTES.proyectos[lang]}>
            {UI.ctaProjects[lang]}
          </a>
        </div>
      </div>
      <div class="hero__media">
        <img
          src="/images/Centro-Comercial-Puruchuco.jpg"
          alt="Centro Comercial Puruchuco — certificación de diseño EDGE"
          fetchpriority="high"
          decoding="async"
        />
        <span class="hero__caption">Centro Comercial Puruchuco · EDGE</span>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section--tight">
    <div class="container stats">
      <Counter value={stats.proyectos} label={stat.proyectos[lang]} suffix="+" />
      <Counter value={stats.asesorias} label={stat.asesorias[lang]} />
      <Counter value={stats.auditorias} label={stat.auditorias[lang]} />
      <Counter value={stats.clientes} label={stat.clientes[lang]} />
    </div>
  </section>

  <!-- Servicios -->
  <section class="section">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">{sections.servicesEyebrow[lang]}</span>
        <h2>{sections.servicesTitle[lang]}</h2>
      </header>
      <div class="services-grid">
        {
          servicios.map((s, i) => (
            <ServiceCard
              servicio={s}
              lang={lang}
              index={i}
              href={`${ROUTES.servicios[lang]}#${s.id}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Proyectos destacados -->
  <section class="section section--alt">
    <div class="container">
      <header class="section-head section-head--row">
        <div>
          <span class="eyebrow">{sections.projectsEyebrow[lang]}</span>
          <h2>{sections.projectsTitle[lang]}</h2>
        </div>
        <a class="link-underline" href={ROUTES.proyectos[lang]}>
          {UI.ctaAllProjects[lang]}
        </a>
      </header>
      <ProjectGrid proyectos={proyectosDestacados} lang={lang} />
    </div>
  </section>

  <!-- Acreditaciones -->
  <section class="section--tight">
    <div class="container">
      <CertBadges lang={lang} />
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container cta">
      <h2 class="cta__title">{sections.ctaTitle[lang]}</h2>
      <p class="lead">{sections.ctaText[lang]}</p>
      <a class="btn btn--solid" href={ROUTES.contacto[lang]}>
        {UI.ctaContact[lang]}<Icon name="arrow" size={18} />
      </a>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use "../../styles/tokens" as *;

  .hero {
    padding-block: clamp(var(--space-l), 6vw, var(--space-2xl));
    border-bottom: 1px solid var(--line);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--space-xl);
    align-items: center;

    @media (max-width: $bp-md) {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
  }
  .hero__title {
    font-size: var(--step-5);
    margin-block: var(--space-xs) var(--space-m);
  }
  .hero__lead {
    max-width: 46ch;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    margin-top: var(--space-l);
  }
  .hero__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius);

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    @media (max-width: $bp-md) {
      aspect-ratio: 16 / 10;
    }
  }
  .hero__caption {
    position: absolute;
    left: 0;
    bottom: 0;
    background: var(--ink);
    color: var(--paper);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.5em 0.9em;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-m);
    padding-block: var(--space-m);
    border-block: 1px solid var(--line);

    @media (max-width: $bp-sm) {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-l) var(--space-m);
    }
  }

  .section--alt {
    background: var(--paper-2);
  }
  .section-head {
    margin-bottom: var(--space-l);
  }
  .section-head--row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-m);
    flex-wrap: wrap;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-m);

    @media (max-width: $bp-lg) {
      grid-template-columns: repeat(2, 1fr);
    }
    @media (max-width: $bp-sm) {
      grid-template-columns: 1fr;
    }
  }

  .cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-m);
    padding-block: var(--space-l);
  }
  .cta__title {
    font-size: var(--step-3);
  }
  .cta .lead {
    max-width: 42ch;
  }
</style>
