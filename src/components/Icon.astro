---
// Iconos SVG en línea (stroke), trazo fino acorde a la estética minimalista.
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: className } = Astro.props;

const paths: Record<string, string> = {
  leaf: '<path d="M11 20A7 7 0 0 1 4 13c0-5 4-9 16-9 0 12-4 16-9 16Z"/><path d="M4 20c2-6 6-9 12-11"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
  shield: '<path d="M12 3l7 3v6c0 4-3 7-7 9-4-2-7-5-7-9V6l7-3Z"/><path d="m9 12 2 2 4-4"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15 9-2 6-4 1 2-6 4-1Z"/>',
  arrow: '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
  whatsapp:
    '<path d="M3 21l1.6-4.6A8 8 0 1 1 8.6 19.4L3 21Z"/><path d="M9 9c0 4 2 6 6 6 .8 0 1.4-.6 1.4-1.4 0-.4-.2-.7-.5-.9l-1.5-.7-.9 1c-1-.4-1.9-1.3-2.3-2.3l1-.9-.7-1.5c-.2-.3-.5-.5-.9-.5C9.6 7.6 9 8.2 9 9Z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  linkedin:
    '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 10v7M8 7v0M12 17v-4a2 2 0 0 1 4 0v4"/>',
};
const inner = paths[name] ?? "";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={inner}
/>
