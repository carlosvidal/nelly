---
import type { Proyecto } from "../lib/content";
import { UI, type Lang } from "../i18n/ui";

interface Props {
  proyecto: Proyecto;
  lang: Lang;
}
const { proyecto, lang } = Astro.props;
const tipoLabel =
  proyecto.tipo === "asesoria" ? UI.tipoAsesoria[lang] : UI.tipoAuditoria[lang];
---

<article class="card" data-tipo={proyecto.tipo}>
  <div class="card__media">
    {
      proyecto.imagen ? (
        <img src={proyecto.imagen} alt={proyecto.nombre} loading="lazy" decoding="async" />
      ) : (
        <div class="card__placeholder" aria-hidden="true">
          <span>{proyecto.nombre.charAt(0)}</span>
        </div>
      )
    }
    <span class="card__tipo">{tipoLabel}</span>
  </div>

  <div class="card__body">
    <h3 class="card__title">{proyecto.nombre}</h3>
    <p class="card__meta">
      {proyecto.ubicacion}{proyecto.cliente ? ` · ${proyecto.cliente}` : ""}
    </p>
    <p class="card__desc">{proyecto.descripcion[lang]}</p>

    {proyecto.nota && <p class="card__nota">{proyecto.nota[lang]}</p>}

    <span class="card__estado">{proyecto.estadoLabel[lang]}</span>
  </div>
</article>

<style lang="scss">
  .card {
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease;

    &:hover {
      border-color: var(--ink);
      transform: translateY(-3px);
    }
  }
  .card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--paper-2);
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
  }
  .card:hover .card__media img {
    transform: scale(1.04);
  }
  .card__placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--paper-2), var(--accent-soft));

    span {
      font-family: var(--font-display);
      font-size: var(--step-4);
      color: color-mix(in srgb, var(--accent) 60%, var(--ink));
      opacity: 0.5;
    }
  }
  .card__tipo {
    position: absolute;
    top: var(--space-xs);
    left: var(--space-xs);
    background: color-mix(in srgb, var(--ink) 85%, transparent);
    color: var(--paper);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35em 0.7em;
    border-radius: var(--radius);
    backdrop-filter: blur(4px);
  }
  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: var(--space-m);
    flex: 1;
  }
  .card__title {
    font-size: var(--step-1);
  }
  .card__meta {
    font-size: var(--step--1);
    color: var(--muted);
  }
  .card__desc {
    font-size: var(--step--1);
    color: var(--ink-2);
    line-height: 1.55;
  }
  .card__nota {
    font-size: var(--step--1);
    color: var(--accent-deep);
    font-style: italic;
    border-left: 2px solid var(--accent);
    padding-left: 0.75em;
  }
  .card__estado {
    margin-top: auto;
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-deep);
    background: var(--accent-soft);
    padding: 0.3em 0.7em;
    border-radius: var(--radius);
  }
</style>
